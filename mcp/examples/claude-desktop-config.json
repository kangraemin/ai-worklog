{
  "mcpServers": {
    "worklog-mcp": {
      "command": "uv",
      "args": [
        "--directory",
        "/ABSOLUTE/PATH/TO/worklog-for-claude/mcp",
        "run",
        "worklog-mcp"
      ],
      "env": {
        "NOTION_TOKEN": "secret_...",
        "NOTION_DB_ID": "your-notion-db-id"
      }
    }
  }
}
